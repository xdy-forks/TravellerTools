@page "/world/{milieuCode}/{sectorHex}/{planetHex}/animals"
@page "/uwp/{uwp}/animals"
@page "/animals/mgt"
@page "/animal-encounters"
@inherits NullablePageBase<WorldModel>

@if (Model != null)
{
    var current = Model.World;

    <h2>@(IsStandaloneRoute ? "Animals" : current.Name)</h2>
    @if (!IsStandaloneRoute)
    {
        <WorldNavigation CurrentPage="animals" World="@Model.World" MilieuCode="@MilieuCode" />
    }
    <div>&nbsp;</div>

    <div class="do-not-print">
        @if (ShowMgtSection)
        {
            <h3>Mongoose 1 Animals</h3>
            <table class="gridtable">
                <tr>
                    <th>Terrain</th>
                    <th>Animal Type</th>
                    <th>Actions</th>
                </tr>
                <tr>
                    <td>
                        <InputSelect @bind-Value="TerrainType" @bind-Value:after="OnMgtTerrainChanged">
                            <option value="">(All Terrains)</option>
                            @foreach (var item in TerrainTypeList)
                            {
                                <option value="@item">@item</option>
                            }
                        </InputSelect>
                    </td>
                    <td>
                        <InputSelect @bind-Value="AnimalType">
                            <option value="">(By Encounter Table)</option>
                            @foreach (var item in AnimalTypeList)
                            {
                                <option value="@item">@item</option>
                            }
                        </InputSelect>
                    </td>
                    <td>
                        <button type="button" disabled="@(CanRerollAnimals)" @onclick="GenerateAnimals">Generate</button>
                        <button type="button" disabled="@(!CanRerollAnimals)" title="Clears the selected terrain tab. If All Terrains is selected, clears all generated results." @onclick="ClearAnimals">Clear</button>
                        <button type="button" disabled="@(!CanRerollAnimals)" @onclick="OnReroll">Reroll</button>
                        <a href="@Permalink">Permalink</a>
                    </td>
                </tr>
            </table>
        }

        @if (ShowAeSection)
        {
            <div>&nbsp;</div>
            <h3>Animal Encounters</h3>
            <table class="gridtable">
                <tr>
                    <th>Terrain</th>
                    <th>Animal Class</th>
                    <th>Actions</th>
                </tr>
                <tr>
                    <td>
                        <InputSelect @bind-Value="AeTerrainType" @bind-Value:after="OnAeTerrainChanged">
                            <option value="">(All Terrains)</option>
                            @foreach (var item in AeTerrainTypeList)
                            {
                                <option value="@item">@item</option>
                            }
                        </InputSelect>
                    </td>
                    <td>
                        <InputSelect @bind-Value="AeAnimalClass">
                            <option value="">(By Encounter Table)</option>
                            @foreach (var item in AeAnimalClassList)
                            {
                                <option value="@item">@item</option>
                            }
                        </InputSelect>
                    </td>
                    <td>
                        <button type="button" disabled="@(CanRerollAnimalEncounters)" @onclick="GenerateAnimalEncounters">Generate</button>
                        <button type="button" disabled="@(!CanRerollAnimalEncounters)" title="Clears the selected terrain tab. If All Terrains is selected, clears all generated results." @onclick="ClearAnimalEncounters">Clear</button>
                        <button type="button" disabled="@(!CanRerollAnimalEncounters)" @onclick="OnReroll">Reroll</button>
                        <a href="@Permalink">Permalink</a>
                    </td>
                </tr>
                <tr>
                    <td colspan="3">Note: detailed meaning aligns with Supplement 11: Animal Encounters.</td>
                </tr>
            </table>
        }
    </div>

    @if (ShowMgtSection && Animals != null)
    {
        <div class="do-not-print terrain-tabs terrain-tabs-sticky">
            <button type="button" class="terrain-tab @(ActiveTerrainTab == "__all__" ? "terrain-tab-active" : "")" @onclick='() => SetMgtTerrainTab("__all__")'>All Terrains</button>
            @foreach (var terrainTab in Animals.Keys.OrderBy(x => x))
            {
                <button type="button" class="terrain-tab @(ActiveTerrainTab == terrainTab ? "terrain-tab-active" : "")" @onclick='() => SetMgtTerrainTab(terrainTab)'>@terrainTab</button>
            }
        </div>

        @foreach (var terrain in DisplayedMgtTerrains)
        {
            <div>&nbsp;</div>
            <h3>@terrain.Key</h3>
            <table class="gridtable">
                <tr>
                    <th width="50">Roll</th>
                    <th colspan="5">Type</th>
                    <th width="70">Move</th>
                    <th width="50">Num.</th>
                    <th width="50">Str</th>
                    <th width="50">Dex</th>
                    <th width="50">End</th>
                    <th width="50">Int</th>
                    <th width="50">Ins</th>
                    <th width="50">Pack</th>
                    <th width="50">Size</th>
                </tr>
                @foreach (var animal in terrain.Value)
                {
                    <tr>
                        <td>@animal.Roll</td>
                        <td colspan="5">@animal.Behavior (@animal.AnimalType)</td>
                        <td>@animal.Movement</td>
                        <td>@animal.NumberEncountered</td>
                        <td>@animal.Strength (@animal.StrengthDM)</td>
                        <td>@animal.Dexterity (@animal.DexterityDM)</td>
                        <td>@animal.Endurance (@animal.EnduranceDM)</td>
                        <td>@animal.Intelligence (@animal.IntelligenceDM)</td>
                        <td>@animal.Instinct (@animal.InstinctDM)</td>
                        <td>@animal.Pack (@animal.PackDM)</td>
                        <td>@animal.WeightKG.ToString("N0") kg</td>
                    </tr>
                    <tr>
                        <th>Skills</th>
                        <td colspan="14">@string.Join(", ", animal.Skills.Select(s => s.Name + " " + s.Level))</td>
                    </tr>
                    <tr>
                        <th>Armor</th>
                        <td>@animal.Armor</td>
                        <th>Weapons</th>
                        <td colspan="12">@string.Join(", ", animal.Weapons.Select(s => s.Name + " " + s.Damage))</td>
                    </tr>
                    <tr>
                        <th colspan="2">Attacks on</th>
                        <td colspan="4">@animal.Attack</td>
                        <th>Flees on</th>
                        <td colspan="8">@animal.Flee</td>
                    </tr>
                }
            </table>
        }
    }

    @if (ShowAeSection && AeAnimals != null)
    {
        <div class="do-not-print terrain-tabs terrain-tabs-sticky">
            <button type="button" class="terrain-tab @(AeActiveTerrainTab == "__all__" ? "terrain-tab-active" : "")" @onclick='() => SetAeTerrainTab("__all__")'>All Terrains</button>
            @foreach (var terrainTab in AeAnimals.Keys.OrderBy(x => x))
            {
                <button type="button" class="terrain-tab @(AeActiveTerrainTab == terrainTab ? "terrain-tab-active" : "")" @onclick='() => SetAeTerrainTab(terrainTab)'>@terrainTab</button>
            }
        </div>

        @foreach (var terrain in DisplayedAeTerrains)
        {
            <div>&nbsp;</div>
            <h3>@terrain.Key (AE)</h3>
            @foreach (var animal in terrain.Value)
            {
                <table class="gridtable">
                    <tr>
                        <th width="150" colspan="3">Name</th>
                        <th width="150" colspan="3">Type</th>
                        <th width="70">Move</th>
                    </tr>
                    <tr>
                        <td colspan="3"></td>
                        <td colspan="3">@animal.AnimalClass (@animal.Diet / @animal.Behavior)</td>
                        <td>@animal.Movement</td>
                    </tr>
                    <tr>
                        <th>Roll</th>
                        <th>Number Appearing</th>
                        <th>Initiative DM</th>
                        <th>Armor</th>
                        <th>Attacks on</th>
                        <th>Flees on</th>
                        <td rowspan="2"></td>
                    </tr>
                    <tr>
                        <td>@animal.Roll</td>
                        <td>@animal.NumberEncountered</td>
                        <td>@animal.InitiativeDM</td>
                        <td>@animal.Armor</td>
                        <td>@animal.Attack</td>
                        <td>@animal.Flee</td>
                    </tr>
                    <tr>
                        <th>Str</th>
                        <th>Dex</th>
                        <th>End</th>
                        <th>Int</th>
                        <th>Ins</th>
                        <th>Pack</th>
                        <th>Size</th>
                    </tr>
                    <tr>
                        <td>@animal.Strength (@animal.StrengthDM)</td>
                        <td>@animal.Dexterity (@animal.DexterityDM)</td>
                        <td>@animal.Endurance (@animal.EnduranceDM)</td>
                        <td>@animal.Intelligence (@animal.IntelligenceDM)</td>
                        <td>@animal.Instinct (@animal.InstinctDM)</td>
                        <td>@animal.Pack (@animal.PackDM)</td>
                        <td>@animal.WeightKG.ToString("N0") kg</td>
                    </tr>
                    @if (animal.Skills.Count > 0)
                    {
                        <tr>
                            <th>Skills</th>
                            <td colspan="15">@string.Join(", ", animal.Skills.Select(s => s.Name + " " + s.Level))</td>
                        </tr>
                    }
                    @if (animal.Weapons.Count > 0)
                    {
                        <tr>
                            <th>Weapons</th>
                            <td colspan="15">@string.Join(", ", animal.Weapons.Select(s => s.Name + " " + s.Damage))</td>
                        </tr>
                    }
                    @foreach (var feature in animal.Features)
                    {
                        <tr>
                            <td colspan="15">@feature.Text</td>
                        </tr>
                    }
                </table>
                <hr />
            }
        }
    }
}

